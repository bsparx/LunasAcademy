          "status": "solved",
          "title": "Why does current efficiency drop in EW?",
          "authorName": "Sam",
          "authorHandle": "sam",
          "replies": 5,
          "upvotes": 16,
          "askedAgo": "1d ago",
          "body": null,
          "answer": {
            "authorName": "Omar K.",
            "authorHandle": "omar-k",
            "isMentor": true,
            "body": "Short circuits are the usual culprit — they bypass useful electrochemical work. Check for stray current paths and dendritic growth on the cathode.",
