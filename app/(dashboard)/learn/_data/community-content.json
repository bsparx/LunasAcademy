        {
          "id": "rc-t6",
          "type": "Question",
          "status": "solved",
          "title": "Does grain size always indicate cooling rate?",
          "authorName": "Omar K.",
          "authorHandle": "omar-k",
          "replies": 6,
          "upvotes": 14,
          "askedAgo": "3d ago",
          "body": "Coarse = slow, fine = fast — but is that always true?",
          "answer": {
            "authorName": "Priya R.",
            "authorHandle": "priya-r",
            "isMentor": true,
            "body": "Mostly yes, but with caveats: very rapid undercooling (e.g. volcanic glass) gives no crystals at all. Grain size is a function of nucleation vs growth rate, not just cooling rate alone.",
            "upvotes": 18,
            "answeredAgo": "2d ago"
          }
        }
      ]
    },
    "geophysics-intro": {
      "courseId": "geophysics-intro",
      "courseTitle": "Introduction to Geophysics",
      "threads": [
        {
          "id": "gp-t1",
          "type": "Question",
          "status": "solved",
          "title": "Why is the S-wave shadow zone bigger than P-wave's?",
          "authorName": "Mehak I.",
          "authorHandle": "mehak-i",
          "replies": 4,
          "upvotes": 22,
          "askedAgo": "2d ago",
          "body": null,
          "answer": {
            "authorName": "Hassan T.",
            "authorHandle": "hassan-t",
            "isMentor": true,
            "body": "S-waves can't pass through the liquid outer core at all, so the shadow is total from ~104° to 180° angular distance. P-waves still refract, so they have a smaller zone (~103° to 140°).",
            "upvotes": 27,
            "answeredAgo": "1d ago"
          }
        },
        {
